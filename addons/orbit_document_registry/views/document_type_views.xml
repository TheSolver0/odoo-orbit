<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="orbit_document_type_tree" model="ir.ui.view">
        <field name="name">orbit.document.type.tree</field>
        <field name="model">orbit.document.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="naming_pattern"/>
            </tree>
        </field>
    </record>

    <record id="orbit_document_type_form" model="ir.ui.view">
        <field name="name">orbit.document.type.form</field>
        <field name="model">orbit.document.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <group string="Nommage automatique">
                        <field name="naming_pattern"
                               placeholder="ex: FP_{client}_{objet}_v{version}"/>
                    </group>
                    <group string="Variables disponibles">
                        <div colspan="2" class="text-muted">
                            <ul>
                                <li><b>{code}</b> → code du type (ex: FP)</li>
                                <li><b>{client}</b> → nom du client sans espaces</li>
                                <li><b>{objet}</b> → objet du document sans espaces</li>
                                <li><b>{version}</b> → numéro de version</li>
                                <li><b>{num:03d}</b> → numéro séquentiel annuel (ex: 001)</li>
                                <li><b>{year}</b> → année (ex: 2026)</li>
                            </ul>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="orbit_document_type_action" model="ir.actions.act_window">
        <field name="name">Types de documents</field>
        <field name="res_model">orbit.document.type</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
