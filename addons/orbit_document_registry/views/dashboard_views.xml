<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="orbit_dashboard_form"
            model="ir.ui.view">

        <field name="name">
            orbit.dashboard.form
        </field>

        <field name="model">
            orbit.dashboard
        </field>

        <field name="arch" type="xml">

            <form create="0"
                  edit="0"
                  delete="0">

                <sheet>

                    <group col="4">

                        <field name="total_documents"/>

                        <field name="total_sent"/>

                        <field name="total_validated"/>

                        <field name="total_cancelled"/>

                    </group>

                </sheet>

            </form>

        </field>

    </record>

</odoo>