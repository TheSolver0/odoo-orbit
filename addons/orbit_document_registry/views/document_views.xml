<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="orbit_document_search" model="ir.ui.view">
        <field name="name">orbit.document.search</field>
        <field name="model">orbit.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="client_id"/>
                <field name="document_type_id"/>
                <field name="objet"/>
                <field name="project_name"/>
                <filter string="Brouillons" name="filter_draft" domain="[('statut','=','draft')]"/>
                <filter string="Transmis" name="filter_sent" domain="[('statut','=','sent')]"/>
                <filter string="Validés" name="filter_validated" domain="[('statut','=','validated')]"/>
                <group expand="0" string="Grouper par" name="group_by_options">
                    <filter string="Client" name="groupby_client" context="{'group_by':'client_id'}"/>
                    <filter string="Type" name="groupby_type" context="{'group_by':'document_type_id'}"/>
                    <filter string="Statut" name="groupby_statut" context="{'group_by':'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="orbit_document_tree" model="ir.ui.view">
        <field name="name">orbit.document.tree</field>
        <field name="model">orbit.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="document_type_id"/>
                <field name="client_id"/>
                <field name="objet"/>
                <field name="project_name"/>
                <field name="statut"/>
            </tree>
        </field>
    </record>

    <record id="orbit_document_form" model="ir.ui.view">
        <field name="name">orbit.document.form</field>
        <field name="model">orbit.document</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate" type="object" string="Valider"
                        class="btn-success"
                        attrs="{'invisible': [('statut', '!=', 'draft')]}"/>
                    <button name="action_mark_as_sent" type="object" string="Transmettre"
                        class="btn-primary"
                        attrs="{'invisible': [('statut', '!=', 'validated')]}"/>
                    <button name="action_cancel" type="object" string="Annuler"
                        class="btn-danger"
                        attrs="{'invisible': [('statut', '=', 'cancelled')]}"/>
                    <field name="statut" widget="statusbar"
                        statusbar_visible="draft,validated,sent,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <group string="Informations">
                            <field name="name"/>
                            <field name="document_type_id"/>
                            <field name="client_id"/>
                            <field name="client_reference"/>
                            <field name="project_name"/>
                            <field name="objet"/>
                            <field name="version"/>
                        </group>
                        <group string="Transmission">
                            <field name="transmitted_by"/>
                            <field name="transmission_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Versions liées">
                            <field name="parent_document_id"/>
                            <field name="child_version_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="version"/>
                                    <field name="statut"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="orbit_document_action" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">orbit.document</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>
