<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        La règle native "see own or unowned stages" est attachée à base.group_user.
        Pour ORer avec elle (et non ANDer), notre règle doit cibler le MÊME groupe.
        Résultat : (1=1) OR (rule_native) = True → tous les stages sont lisibles.
    -->
    <record id="orbit_stage_read_rule" model="ir.rule">
        <field name="name">Orbit: étapes de workflow lisibles par tous</field>
        <field name="model_id" ref="project.model_project_task_type"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
